{
  "version": 2,
 "crons": [
    {
      "path": "/cron/resolve-matches",
      "schedule": "0 0 * * *" 
    }
  ],
  "functions": {
    "app.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/app.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}